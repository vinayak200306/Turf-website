generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  phone         String         @unique
  countryCode   String         @default("+91")
  name          String?
  email         String?        @unique
  avatarUrl     String?
  role          Role           @default(USER)
  isActive      Boolean        @default(true)
  fcmToken      String?
  walletBalance Float          @default(0)
  memberTier    MemberTier     @default(BRONZE)
  totalBookings Int            @default(0)
  refreshToken  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  venueOwner     VenueOwner?
  bookings       Booking[]
  reviews        Review[]
  notifications  Notification[]
  savedVenues    SavedVenue[]
  otps           OtpLog[]
}

model OtpLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  otp        String
  expiresAt  DateTime
  verified   Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

model Sport {
  id        String       @id @default(cuid())
  name      String       @unique
  emoji     String
  isActive  Boolean      @default(true)
  venues    VenueSport[]
  slots     Slot[]
  bookings  Booking[]
}

model Venue {
  id           String        @id @default(cuid())
  name         String
  description  String
  ownerId      String
  owner        VenueOwner    @relation(fields: [ownerId], references: [id])
  addressLine  String
  city         String
  state        String
  pincode      String
  latitude     Float
  longitude    Float
  openTime     String
  closeTime    String
  isActive     Boolean       @default(true)
  isApproved   Boolean       @default(false)
  avgRating    Float         @default(0)
  totalReviews Int           @default(0)
  images       VenueImage[]
  amenities    Json
  sports       VenueSport[]
  slots        Slot[]
  bookings     Booking[]
  reviews      Review[]
  savedBy      SavedVenue[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model VenueOwner {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  businessName String
  gstNumber    String?
  bankAccount  Json
  venues       Venue[]
  createdAt    DateTime @default(now())
}

model VenueImage {
  id        String   @id @default(cuid())
  venueId   String
  venue     Venue    @relation(fields: [venueId], references: [id])
  url       String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
}

model VenueSport {
  id           String  @id @default(cuid())
  venueId      String
  venue        Venue   @relation(fields: [venueId], references: [id])
  sportId      String
  sport        Sport   @relation(fields: [sportId], references: [id])
  pricePerHour Float
  pitchName    String  @default("Main Pitch")
  maxPlayers   Int     @default(10)

  @@unique([venueId, sportId])
}

model Slot {
  id          String      @id @default(cuid())
  venueId     String
  venue       Venue       @relation(fields: [venueId], references: [id])
  sportId     String
  sport       Sport       @relation(fields: [sportId], references: [id])
  date        String
  startTime   String
  endTime     String
  durationHrs Int         @default(1)
  priceTotal  Float
  status      SlotStatus  @default(AVAILABLE)
  lockedUntil DateTime?
  booking     Booking?
  createdAt   DateTime    @default(now())

  @@unique([venueId, sportId, date, startTime, endTime])
  @@index([venueId, date, sportId, status])
}

model Booking {
  id             String         @id @default(cuid())
  bookingRef     String         @unique
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  venueId        String
  venue          Venue          @relation(fields: [venueId], references: [id])
  slotId         String         @unique
  slot           Slot           @relation(fields: [slotId], references: [id])
  sportId        String
  sport          Sport          @relation(fields: [sportId], references: [id])
  slotFee        Float
  gstAmount      Float
  convenienceFee Float          @default(20)
  totalAmount    Float
  status         BookingStatus  @default(PENDING)
  cancelReason   String?
  refundStatus   RefundStatus?
  refundAmount   Float?
  payment        Payment?
  review         Review?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId, status, createdAt])
}

model Payment {
  id                String         @id @default(cuid())
  bookingId         String         @unique
  booking           Booking        @relation(fields: [bookingId], references: [id])
  razorpayOrderId   String         @unique
  razorpayPaymentId String?
  razorpaySignature String?
  razorpayRefundId  String?
  amount            Float
  currency          String         @default("INR")
  method            PaymentMethod?
  status            PaymentStatus  @default(CREATED)
  failureReason     String?
  paidAt            DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  venueId    String
  venue      Venue    @relation(fields: [venueId], references: [id])
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  rating     Int
  comment    String
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([venueId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}

model SavedVenue {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  venueId   String
  venue     Venue    @relation(fields: [venueId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, venueId])
}

enum Role {
  USER
  VENUE_OWNER
  ADMIN
}

enum MemberTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum SlotStatus {
  AVAILABLE
  LOCKED
  BOOKED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUND_INITIATED
}

enum RefundStatus {
  INITIATED
  PROCESSED
  FAILED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  WALLET
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  REFUND_PROCESSED
  SLOT_REMINDER
  GENERAL
}
