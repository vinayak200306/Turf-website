NODE_ENV=production
PORT=10000
APP_URL=https://api.yourdomain.com
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://www.yourdomain.com

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require
REDIS_URL=rediss://default:<password>@<host>:6379

ACCESS_TOKEN_SECRET=replace_with_strong_access_secret_min_32_chars
REFRESH_TOKEN_SECRET=replace_with_strong_refresh_secret_min_32_chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_live_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_webhook_secret

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

AWS_ACCESS_KEY_ID=replace_with_aws_key
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=fielddoor-media
CDN_URL=https://media.yourdomain.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=replace_with_smtp_password
EMAIL_FROM=Field Door <noreply@yourdomain.com>

SLOT_LOCK_TTL_SECONDS=600
GST_RATE=0.18
CONVENIENCE_FEE=20
CANCELLATION_FULL_REFUND_HOURS=24
CANCELLATION_PARTIAL_REFUND_HOURS=12
CANCELLATION_PARTIAL_REFUND_PCT=0.5
